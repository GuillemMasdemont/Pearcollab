{
  "name": "pearcollab",
  "displayName": "PearCollab",
  "description": "Real-time P2P collaborative code editing — no server, no account",
  "version": "0.1.0",
  "publisher": "pearcollab",
  "engines": { "vscode": "^1.80.0" },
  "categories": ["Other"],
  "activationEvents": ["onStartupFinished"],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "pearcollab.startSession",
        "title": "PearCollab: Start Session"
      },
      {
        "command": "pearcollab.joinSession",
        "title": "PearCollab: Join Session"
      },
      {
        "command": "pearcollab.endSession",
        "title": "PearCollab: End Session"
      },
      {
        "command": "pearcollab.copyRoomName",
        "title": "PearCollab: Copy Room Name"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "pearcollab",
          "title": "PearCollab",
          "icon": "media/icon.svg"
        }
      ]
    },
    "views": {
      "pearcollab": [
        {
          "type": "webview",
          "id": "pearcollab.sidebar",
          "name": "Session"
        }
      ]
    },
    "configuration": {
      "title": "PearCollab",
      "properties": {
        "pearcollab.displayName": {
          "type": "string",
          "default": "",
          "description": "Your display name shown to collaborators in PearCollab sessions."
        }
      }
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "vscode:prepublish": "npm run compile",
    "setup": "npm install && cd sidecar && npm install"
  },
  "dependencies": {
    "ignore": "^5.3.1",
    "yjs": "^13.6.14"
  },
  "devDependencies": {
    "@types/node": "^18.0.0",
    "@types/vscode": "^1.80.0",
    "typescript": "^5.0.0"
  }
}
